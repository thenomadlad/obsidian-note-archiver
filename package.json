{
	"name": "obsidian-note-archiver",
	"version": "0.1.0",
	"description": "Tools to archive your notes in another folder",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test:e2e": "wdio run wdio.conf.mts"
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"@wdio/cli": "^9.27.2",
		"@wdio/globals": "^9.27.2",
		"@wdio/local-runner": "^9.27.2",
		"@wdio/mocha-framework": "^9.27.2",
		"@wdio/spec-reporter": "^9.27.2",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"tsx": "^4.22.4",
		"typescript": "4.7.4",
		"wdio-obsidian-service": "^3.0.4"
	}
}
